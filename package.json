{
  "name": "oclite-vscode",
  "displayName": "OCLite",
  "description": "AI-powered generation management for VS Code",
  "version": "0.1.59",
  "publisher": "oclitesite",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "ai",
    "image generation",
    "gallery",
    "azure",
    "oclite"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:oclite.sidebarView",
    "onView:oclite.chatView",
    "onCommand:oclite.generateImage",
    "onCommand:oclite.viewGallery",
    "onCommand:oclite.chatWithAI",
    "onCommand:oclite.openCanvas",
    "onCommand:oclite.diagnostics",
    "onCommand:oclite-vscode.analyzeAndGenerate",
    "onChatParticipant:oclite"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "oclite.generateImage",
        "title": "Generate Image",
        "category": "OCLite"
      },
      {
        "command": "oclite.viewGallery",
        "title": "View My Gallery",
        "category": "OCLite"
      },
      {
        "command": "oclite.chatWithAI",
        "title": "Chat with AI",
        "category": "OCLite"
      },
      {
        "command": "oclite.openCanvas",
        "title": "Open Canvas (Excalidraw)",
        "category": "OCLite"
      },
      {
        "command": "oclite.signInMicrosoft",
        "title": "Sign In Microsoft",
        "category": "OCLite"
      },
      {
        "command": "oclite.signOut",
        "title": "Sign Out",
        "category": "OCLite"
      },
      {
        "command": "oclite.diagnostics",
        "title": "Diagnostics",
        "category": "OCLite"
      },
      {
        "command": "oclite.rateLimitStatus",
        "title": "Rate Limit Status",
        "category": "OCLite"
      },
      {
        "command": "oclite.sharingStats",
        "title": "Sharing Stats",
        "category": "OCLite"
      },
      {
        "command": "oclite.setBackground",
        "title": "Set Background",
        "category": "OCLite"
      },
      {
        "command": "oclite.removeBackground",
        "title": "Remove Background",
        "category": "OCLite"
      },
      {
        "command": "oclite.removeTheme",
        "title": "Remove Theme",
        "category": "OCLite"
      },
      {
        "command": "oclite-vscode.analyzeAndGenerate",
        "title": "Analyze & Generate",
        "category": "OCLite"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "oclite-vscode.analyzeAndGenerate",
          "when": "true",
          "group": "oclite"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "oclite",
        "name": "oclite",
        "description": "AI-powered image generation and coding assistant",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oclite-sidebar",
          "title": "OCLite",
          "icon": "assets/icon-light.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "oclite.sidebarView",
          "name": "OCLite Generator",
          "type": "webview",
          "when": "true",
          "icon": "$(sparkle)"
        }
      ],
      "oclite-sidebar": [
        {
          "id": "oclite.chatView",
          "name": "OCLite Chat",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "OCLite",
      "properties": {
        "oclite.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key for AI chat functionality"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/extension-telemetry": "^1.5.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.28.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "ts-loader": "^9.4.1",
    "typescript": "^4.9.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "axios": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oclite/oclite-vscode.git"
  }
}