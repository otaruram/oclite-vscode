{
  "name": "oclite-vscode",
  "displayName": "OCLite - AI Image Generator & Gallery",
  "description": "AI-powered image generation with instant gallery, cloud storage, and secure sharing. Generate game assets, UI mockups, and art with SDXL, Flux, and GPT-4o mini.",
  "version": "0.1.67",
  "publisher": "oclitesite",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "ai",
    "image generation",
    "gallery",
    "image gallery",
    "ai art",
    "ai image",
    "stable diffusion",
    "sdxl",
    "flux",
    "midjourney alternative",
    "dall-e alternative",
    "game assets",
    "game art",
    "ui mockup",
    "design",
    "creative",
    "azure",
    "cloud storage",
    "image manager",
    "asset manager",
    "copilot",
    "gpt-4",
    "chatgpt",
    "openai",
    "replicate",
    "hugging face",
    "automatic1111",
    "comfyui",
    "oclite",
    "photo editor",
    "image editor",
    "visual studio code",
    "vscode extension",
    "developer tools",
    "productivity",
    "workflow",
    "automation"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Data Science",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:oclite.sidebarView",
    "onView:oclite.chatView",
    "onChatParticipant:oclite"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "oclite.generateImage",
        "title": "Generate Image",
        "category": "OCLite"
      },
      {
        "command": "oclite.viewGallery",
        "title": "View My Gallery",
        "category": "OCLite"
      },
      {
        "command": "oclite.chatWithAI",
        "title": "Chat with AI",
        "category": "OCLite"
      },
      {
        "command": "oclite.openCanvas",
        "title": "Open Canvas (Excalidraw)",
        "category": "OCLite"
      },
      {
        "command": "oclite.signInMicrosoft",
        "title": "Sign In Microsoft",
        "category": "OCLite"
      },
      {
        "command": "oclite.signOut",
        "title": "Sign Out",
        "category": "OCLite"
      },
      {
        "command": "oclite.diagnostics",
        "title": "Diagnostics",
        "category": "OCLite"
      },
      {
        "command": "oclite.rateLimitStatus",
        "title": "Rate Limit Status",
        "category": "OCLite"
      },
      {
        "command": "oclite.sharingStats",
        "title": "Sharing Stats",
        "category": "OCLite"
      },
      {
        "command": "oclite.setBackground",
        "title": "Set Background",
        "category": "OCLite"
      },
      {
        "command": "oclite.removeBackground",
        "title": "Remove Background",
        "category": "OCLite"
      },
      {
        "command": "oclite.removeTheme",
        "title": "Remove Theme",
        "category": "OCLite"
      },
      {
        "command": "oclite-vscode.analyzeAndGenerate",
        "title": "Analyze & Generate",
        "category": "OCLite"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "oclite-vscode.analyzeAndGenerate",
          "when": "true",
          "group": "oclite"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "oclite",
        "name": "oclite",
        "description": "🎨 Your cute AI art buddy! Generate images, game assets & more",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oclite-sidebar",
          "title": "OCLite Studio",
          "icon": "assets/icon-light.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "oclite.sidebarView",
          "name": "🎨 OCLite Generator",
          "type": "webview",
          "when": "true",
          "icon": "$(paintcan)"
        }
      ],
      "oclite-sidebar": [
        {
          "id": "oclite.chatView",
          "name": "💬 OCLite Chat",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "OCLite",
      "properties": {
        "oclite.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key for AI chat functionality"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/extension-telemetry": "^1.5.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.28.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "ts-loader": "^9.4.1",
    "typescript": "^4.9.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "axios": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oclite/oclite-vscode.git"
  }
}
